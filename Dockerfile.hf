FROM debian:bookworm-slim
RUN apt-get update && apt-get install -y ca-certificates && rm -rf /var/lib/apt/lists/*
RUN useradd -m -u 1000 app
USER 1000
WORKDIR /home/app
COPY orchestrator ./orchestrator
COPY static/ ./static/
RUN mkdir -p data/voiceprints
ENV PORT=7860
EXPOSE 7860
CMD ["./orchestrator"]
